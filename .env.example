# 企业微信机器人配置
WECOM_BOT_ID=your_bot_id_here
WECOM_BOT_SECRET=your_bot_secret_here
# 企业微信 WebSocket 真实服务地址
WECOM_WS_URL=wss://openws.work.weixin.qq.com

# 大模型 (LLM) 配置
LLM_API_KEY=your_llm_api_key_here
LLM_BASE_URL=https://your_llm_api_base_url_here
LLM_MODEL_NAME=MiniMax-M2.5
# 递归限制（控制 AI 思考深度/ReAct 次数，默认 25）
LLM_RECURSION_LIMIT=25

# MCP 工具服务器配置 (任选其一)
# 方式 A: 单个服务器简易配置 (Legacy)
MCP_REMOTE_URL=http://your_mcp_server_ip:1348/sse

# 方式 B: 多个服务器详细配置 (推荐, JSON 数组字符串)
# MCP_SERVERS=[{"name":"gitnexus","url":"http://ip:1348/sse","type":"sse"},{"name":"db","url":"http://ip:1248/sse","type":"sse"}]

# 可选：允许使用的 MCP 工具列表（英文逗号分隔），为空则允许所有工具
# ALLOWED_TOOLS=tool_name_1,tool_name_2

# 可选：排除使用的 MCP 工具列表（英文逗号分隔），为空则不排除
# 示例：排除所有数据库写入和删改操作
# EXCLUDED_TOOLS=write_query,create_table,alter_table,drop_table
